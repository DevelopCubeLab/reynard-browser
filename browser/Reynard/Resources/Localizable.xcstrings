    "%@ are disabled for Reynard. Open Settings to allow access." : {
      "comment" : "Permission list placeholder",
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@已在Reynard中禁用。请打开设置以允许访问。"
          }
        }
      }
    },
    "%@ has been updated. Approve the additional permissions before the updated version is installed. Dismissing this prompt keeps your current add-on version." : {
      "comment" : "Add-on name",
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@已更新。请先允许新的权限，然后再安装新版本。关闭此提示将保留您当前的扩展版本。"
          }
        }
      }
    },
    "%@ is disabled for Reynard. Open Settings to allow access." : {
      "comment" : "Permission list placeholder",
